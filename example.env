# Copy to .env and adjust. Used by scripts (load_dotenv).

# App key for shared folders (required): 64 hex chars (32 bytes). Generate: python -c "import secrets; print(secrets.token_hex(32))"
# SECURE_STORAGE_APP_KEY=<64_hex_chars>

# Base directory for persistent data (default: project_root/data)
# SECURE_STORAGE_DATA_ROOT=/path/to/data

# Override paths individually (default: $SECURE_STORAGE_DATA_ROOT or project_root/data)
# SECURE_STORAGE_KMS_DIR=/path/to/kms_store
# SECURE_STORAGE_FILE_BIN=/path/to/file_bin
# SECURE_STORAGE_SESSION_FILE=/path/to/.session

# PBKDF2 iterations for key derivation (default: 600000)
# SECURE_STORAGE_KDF_ITERATIONS=600000
